msgid "UWB模块可以自动标定基站吗"
msgstr "Can the UWB module automatically calibrate base stations?"

#: ../../source/docs/software-framework/UWB/index.rst:532 5423394cd9564f81b45deb72e682c690
msgid "模块没有这个功能"
msgstr "The module does not have this function."

#: ../../source/docs/software-framework/UWB/index.rst:535 d3d5ccdd3b1d48d9876b2a2deb99ee22
msgid "UWB模块位置信号一般多久发送一次"
msgstr "How often is the UWB module’s position signal generally sent?"

#: ../../source/docs/software-framework/UWB/index.rst:536 bae4b37040954fec95c655c8438cbb31
msgid "一般1秒钟发送一次位置信息"
msgstr "Generally, position information is sent once per second."

#: ../../source/docs/software-framework/UWB/index.rst:539 19cd75501efd4d609f0137701d326e4b
msgid "UWB开发板测距频率能加快吗"
msgstr "Can the ranging frequency of the UWB development board be increased?"

