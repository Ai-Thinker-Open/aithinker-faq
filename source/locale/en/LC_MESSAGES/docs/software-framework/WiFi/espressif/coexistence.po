#: 8b17505e17654523bd1c98f3c5e2eaa3
msgid "ESP32 支持 16MB 的 External Flash 和 8MB 的 External PSRAM 共存吗？"
msgstr ""

#: ../../source/docs/software-framework/WiFi/espressif/coexistence.rst:41
#: e828d20468e54952a404bdc0b93d95e2
msgid "ESP32 可以支持 16MB 的 External Flash 和 8MB 的 External PSRAM 共存使用。"
msgstr ""

#: ../../source/docs/software-framework/WiFi/espressif/coexistence.rst:46
#: 23383725700a4db7898ababf4ae385de
msgid "ESP32 Wi-Fi Mesh 和 BLE Mesh 可以同时支持吗？"
msgstr ""

#: ../../source/docs/software-framework/WiFi/espressif/coexistence.rst:48
#: 8b17e976c1bb407ca878dcab33177681
msgid ""
"不支持，补充一点：ESP32 Wi-Fi Mesh 和 BLE 可以同时支持，或者 ESP32 Wi-Fi STA 模式和 BLE Mesh "
"可以同时支持。"
msgstr ""

#: ../../source/docs/software-framework/WiFi/espressif/coexistence.rst:53
