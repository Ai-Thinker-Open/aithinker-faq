#: 0565c025971d4607af10a79d4f2842a3
msgid "eg: run -> init (fc0)，fc0 含义为 STA 收到了 deauth 帧，reason 为密码错误。"
msgstr ""

#: ../../source/docs/software-framework/WiFi/espressif/wifi.rst:350
#: 20009af5ee064080a88b4e8853e25f73
msgid "c0 代表收到的帧类型（00 代表超时）"
msgstr ""

#: ../../source/docs/software-framework/WiFi/espressif/wifi.rst:351
#: 1914d41e052640968d0b05bbd76a9322
