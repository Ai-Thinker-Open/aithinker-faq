msgstr "This error is reported when the ESP8266 receives packets retransmitted by the router several times, but it does not affect usage."

#: ../../source/docs/software-framework/WiFi/espressif/wifi.rst:668 6fd6bd0101d94089b16bbb18be238e9a
msgid "ESP32 WFA 认证支持 Multicast 吗？"
