msgid "直接选择ESP32 Dev module即可"
msgstr "Select ESP32 Dev module directly."

#: ../../source/docs/software-framework/WiFi/espressif/wifi.rst:689 b0701ac753f64fae8b1ca89e68f0748c
msgid "ESP系列的串口电平是232电平还是TTL电平"
msgstr "Are the serial port levels of ESP series modules RS232 level or TTL level?"

